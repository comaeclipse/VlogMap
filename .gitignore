# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# playwright mcp artifacts
.playwright-mcp/

# agent / tooling config and docs (kept local, not tracked)
.claude/
.serena/
AGENTS.md
CLAUDE.md

# database migrations (kept local, not tracked)
/migrations/

# typescript
*.tsbuildinfo
next-env.d.ts
